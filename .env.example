# FounderOS environment variables
# Copy this file to .env.local and fill in values as needed.
# All variables are optional — the app runs fully in mock mode without them.

# ─── Scrape provider ──────────────────────────────────────────────────────────
#
# Accepted values:
#   (unset or empty) — defaults to "mock"
#   mock             — built-in mock provider, returns fixture content, no network calls
#   anakin           — Anakin URL Scraper (https://api.anakin.io) — RECOMMENDED
#   real / jina      — Jina AI Reader (https://r.jina.ai/) — fallback option
#
# The app always falls back to mock mode when this is unset or unrecognised.
SCRAPE_PROVIDER=

# ─── Anakin URL Scraper ───────────────────────────────────────────────────────
#
# Required when SCRAPE_PROVIDER=anakin.
# Obtain your key from https://anakin.io/dashboard
# Key format: ask_...
ANAKIN_API_KEY=

# Optional — override the Anakin API base URL (default: https://api.anakin.io)
ANAKIN_BASE_URL=

# ─── Jina AI Reader ───────────────────────────────────────────────────────────
#
# Optional — only used when SCRAPE_PROVIDER=real or SCRAPE_PROVIDER=jina.
# Basic usage is free without a key.
# Obtain a key at https://jina.ai/reader/ to raise rate limits.
JINA_API_KEY=
