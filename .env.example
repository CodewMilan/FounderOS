# FounderOS environment variables
# Copy this file to .env.local and fill in your values.

NODE_ENV=development
NEXT_PUBLIC_APP_NAME=FounderOS

# Supabase (browser auth + optional server profile sync)
# URL is safe to expose; use the anon (publishable) key for NEXT_PUBLIC_* — never the service role key in client code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: server-only service role for admin/table writes (see lib/services/supabaseClient.ts)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# Scrape provider: "anakin" | "mock" (default: mock)
SCRAPE_PROVIDER=mock

# Anakin URL Scraper (https://api.anakin.ai)
ANAKIN_API_KEY=

# Jina AI (alternative scraper)
JINA_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack webhooks
SLACK_WEBHOOK_URL=
SLACK_DEV_TICKETS_WEBHOOK_URL=

# Lemon Squeezy (pricing update workflow — approval-gated)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_VARIANT_ID=

# Your own site URL (used for comparison in feature-gap and pricing-response)
USER_SITE_URL=
