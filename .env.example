# FounderOS environment variables
# Copy this file to .env.local and fill in your values.

NODE_ENV=development
NEXT_PUBLIC_APP_NAME=FounderOS

# Scrape provider: "anakin" | "mock" (default: mock)
SCRAPE_PROVIDER=mock

# Anakin URL Scraper (https://api.anakin.ai)
ANAKIN_API_KEY=

# Jina AI (alternative scraper)
JINA_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack webhooks
SLACK_WEBHOOK_URL=
SLACK_DEV_TICKETS_WEBHOOK_URL=

# Lemon Squeezy (pricing update workflow — approval-gated)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_VARIANT_ID=

# Your own site URL (used for comparison in feature-gap and pricing-response)
USER_SITE_URL=
