# FounderOS environment variables
# Copy this file to .env.local and fill in your values.

NODE_ENV=development
NEXT_PUBLIC_APP_NAME=FounderOS

# Scrape provider: "anakin" | "mock" (default: mock)
SCRAPE_PROVIDER=mock

# Anakin URL Scraper (https://api.anakin.ai)
ANAKIN_API_KEY=

# Jina AI (alternative scraper)
JINA_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Telegram Bot (for Competitor Intelligence alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
